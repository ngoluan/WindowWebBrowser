<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- WindowWeb is a general browser, so explicit HTTP URLs remain supported. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- User-installed development CAs are trusted only in debuggable builds. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
